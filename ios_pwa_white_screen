// Detect Apple devices once at worker startup.
// /Macintosh/ included because iPadOS 13+ reports a Mac UA.
// Do NOT use navigator.maxTouchPoints here - it does not
// exist in the service worker context (WorkerNavigator)
// and would silently break iPad detection.
const APEX_SW_APPLE_BYPASS =
    /iPhone|iPad|iPod|Macintosh/i.test(self.navigator.userAgent);

if (APEX_SW_APPLE_BYPASS) {
    console.info('[APEX SW] Apple device detected - fetch bypass active');
}


