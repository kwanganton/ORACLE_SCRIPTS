--               minutes_running, sql_id, kill_reason, error_message,SQL_TEXT
--             ) VALUES (
--               s.sid, s.serial#, s.username, s.program, s.module,
--               s.minutes_running, s.sql_id,
--               'Auto-killed: exceeded ' || p_minutes_threshold || ' min',
--               NULL, (select sql_text from V$SQL x where x.sql_id = s.sql_id)
--             );
--
--           EXCEPTION
--             WHEN OTHERS THEN
--               v_sql_error := SQLERRM;
--               INSERT INTO session_kill_log (
--                 sid, serial#, username, program, module,
--                 minutes_running, sql_id, kill_reason, error_message, SQL_TEXT
--               ) VALUES (
--                 s.sid, s.serial#, s.username, s.program, s.module,
--                 s.minutes_running, s.sql_id,
--                 'Kill attempt failed (threshold ' || p_minutes_threshold || ' min)',
--                 v_sql_error,  (select sql_text from V$SQL x where x.sql_id = s.sql_id and ROWNUM=1)
--               );
--           END;
         END IF;
      END IF;
    END;
  END LOOP;

  COMMIT;
END;
