declare
        v_sql_error clob;
    p_minutes_threshold number :=1;
BEGIN
  FOR s IN (
    SELECT s.sid,
           s.serial#,
           s.username,
           s.status,
           s.sql_id,
           s.module,
           s.program,
           s.last_call_et / 60 AS minutes_running
    FROM   v$session s
    WHERE  s.status = 'ACTIVE'
      AND  s.username IS NOT NULL
      --AND  s.username <> 'SYS'
    ORDER BY s.last_call_et DESC
  )
  LOOP
    BEGIN
      IF s.minutes_running > p_minutes_threshold THEN
        -- Skip internal APEX jobs and self-kill
        IF s.module NOT LIKE 'WWV_FLOW%' AND USER != s.username THEN
--          BEGIN
            rdsadmin.rdsadmin_util.kill(
              sid    => s.sid,
              serial => s.serial#,
              method => 'IMMEDIATE'
            );
--
