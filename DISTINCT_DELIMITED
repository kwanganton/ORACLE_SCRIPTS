CREATE OR REPLACE FUNCTION F_DISTINCT_DELIMITED 
(
  IN_DELIMITED IN VARCHAR2 
) RETURN VARCHAR2 AS 
v_distinct varchar2(4000);
BEGIN


 SELECT LISTAGG(DISTINCT val, ':') 
         WITHIN GROUP (ORDER BY val)
  INTO v_distinct
  FROM (
    SELECT REGEXP_SUBSTR(IN_DELIMITED, '[^:]+', 1, LEVEL) val
    FROM dual
    CONNECT BY REGEXP_SUBSTR(IN_DELIMITED, '[^:]+', 1, LEVEL) IS NOT NULL
  );
  
  return v_distinct;
  
END F_DISTINCT_DELIMITED;
