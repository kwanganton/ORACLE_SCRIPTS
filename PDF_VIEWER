# Function and Global Variable Declaration

Create a page-level JavaScript declaration.

```javascript
window.apexPdfViewer = {
    pdfDocument: null,
    scale: 1,
    rendering: false,
    pdfUrl: null,

    async renderAllPages() {

        const viewer = document.getElementById("pdfViewer");
        const status = document.getElementById("pdfStatus");

        if (!viewer || !status || !this.pdfDocument || this.rendering) {
            return;
        }

        this.rendering = true;
        viewer.innerHTML = "";

        status.hidden = false;
        status.textContent = "Rendering PDF...";

        try {

            for (let pageNumber = 1;
                 pageNumber <= this.pdfDocument.numPages;
                 pageNumber++) {

                status.textContent =
                    "Rendering page " +
                    pageNumber +
                    " of " +
                    this.pdfDocument.numPages +
                    "...";

                const page =
                    await this.pdfDocument.getPage(pageNumber);

                const viewport =
                    page.getViewport({
                        scale: this.scale
                    });

                const outputScale =
                    window.devicePixelRatio || 1;

                const canvas =
                    document.createElement("canvas");

                const context =
                    canvas.getContext("2d", {
                        alpha: false
                    });

                canvas.className = "apex-pdf-page";

                canvas.width =
                    Math.floor(viewport.width * outputScale);

                canvas.height =
                    Math.floor(viewport.height * outputScale);

                canvas.style.width =
                    Math.floor(viewport.width) + "px";

                canvas.style.height =
                    Math.floor(viewport.height) + "px";

                viewer.appendChild(canvas);

                await page.render({
                    canvasContext: context,
                    viewport: viewport,
                    transform:
                        outputScale !== 1
                            ? [outputScale,0,0,outputScale,0,0]
                            : null
                }).promise;
            }

            status.hidden = true;

        } finally {

            this.rendering = false;

        }
    },

    async load(pdfjsLib) {

        const status =
            document.getElementById("pdfStatus");

        if (!this.pdfUrl) {

            status.textContent =
                "No PDF URL supplied.";

            return;
        }

        status.textContent = "Loading PDF...";

        const loadingTask =
            pdfjsLib.getDocument({
                url: this.pdfUrl
            });

        this.pdfDocument =
            await loadingTask.promise;

        await this.renderAllPages();
    },

    async changeZoom(amount) {

        if (this.rendering) {
            return;
        }

        const newScale = Math.min(
            2.5,
            Math.max(
                0.1,
                Number((this.scale + amount).toFixed(1))
            )
        );

        if (newScale === this.scale) {
            return;
        }

        this.scale = newScale;

        document.getElementById("pdfZoomLevel")
            .textContent =
            Math.round(this.scale * 100) + "%";

        await this.renderAllPages();
    }
};
```

